{
  "name": "pushka",
  "type": "module",
  "scripts": {
    "start": "node src/main.ts",
    "dev": "node --watch src/main.ts",
    "test:env": "node --test tests/env/**/*.test.ts",
    "test:sqliteStore": "node --test tests/sqliteStore/**/*.test.ts",
    "test:integration": "node --test tests/integration/**/*.test.ts",
    "test:playwright": "npx playwright test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "simple-git-hooks || true"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run lint && npm run format:check"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "prettier": "^3.9.6",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0"
  },
  "engines": {
    "node": ">= 24.0.0"
  }
}
